# DeepSeek LLM 配置
# 官方模型名：https://platform.deepseek.com/api-docs/zh-cn/quick_start/model_capabilities
# 当前推荐：deepseek-v4-flash（轻量） / deepseek-v4-pro（专业）
# deepseek-chat 将于 2026/07/24 弃用
DEEPSEEK_API_KEY=your_deepseek_api_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7

# Embedding 配置（DeepSeek 暂无 Embedding API，推荐用 OpenAI 或硅基流动）
EMBEDDING_API_KEY=your_embedding_api_key_here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# 向量库配置
VECTOR_DB_PATH=./data/vector_db
COLLECTION_NAME=scheduling_kb

# 检索配置
RETRIEVAL_TOP_K=5
RETRIEVAL_RERANK_TOP_K=5
RETRIEVAL_RERANK_CANDIDATE_K=20

# Hybrid Search（BM25 + 向量融合检索）
# 启用后自动创建 FTS5 全文索引，与向量检索结果进行 RRF 融合
# HYBRID_SEARCH_ENABLED=true
# HYBRID_SEARCH_ALPHA=0.3     # BM25 权重（0=纯向量, 1=纯 BM25）
# HYBRID_SEARCH_FETCH_K=40    # 每种搜索方式拉取候选数
# HYBRID_SEARCH_RRF_K=60      # RRF 融合常数

# Embedding 回退（当主 Embedding 不可用时自动切换）
# EMBEDDING_FALLBACK_API_KEY=
# EMBEDDING_FALLBACK_BASE_URL=https://api.openai.com/v1
# EMBEDDING_FALLBACK_MODEL=text-embedding-3-small

# Reranker 精排配置（默认复用 Embedding API，也可独立配置）
# RERANKER_API_KEY=
# RERANKER_BASE_URL=
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_ENTRIES=200

# 数据库配置（默认 SQLite，部署可换 PostgreSQL）
DATABASE_URL=sqlite:///./data/chat.db
# DATABASE_URL=postgresql://user:password@localhost:5432/chat

# 置信度配置（低于此值的回答会标注"仅供参考"）
CONFIDENCE_THRESHOLD=0.5

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000

# Redis 配置（默认 localhost:6379，Docker Compose 部署时自动使用 service 名称）
REDIS_URL=redis://localhost:6379/0

# 限流配置（默认值适合单用户场景，生产环境可根据并发调整）
# RATE_LIMIT_CHAT=30/minute
# RATE_LIMIT_CHAT_STREAM=10/minute
# RATE_LIMIT_DOCUMENTS=5/minute

# JWT 配置（secret 空则自动生成，提供 refresh 机制）
# JWT_SECRET=
# JWT_ACCESS_EXPIRE_MINUTES=30
# JWT_REFRESH_EXPIRE_DAYS=7

# 管理员密码（留空则关闭管理员登录功能）
ADMIN_PASSWORD=

# Docker Compose 部署配置（REGISTRY_URL 放在项目根目录的 .env 中）
# 项目根目录 .env 示例：REGISTRY_URL=<your-registry>:5000/
